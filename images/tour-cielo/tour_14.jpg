		$.get(url, function(data) {
			var catelist = "<li><a href=https://thisiscozumel.com/tours>All Cozumel Tours</a></li>";

			if(data) {
				$.each(data['data'], function(i, cate) {
					var slug = "https://thisiscozumel.com/tours/category/" + cate['slug'];

					catelist = catelist + "<li><a href="+slug+">"+cate['name']+"</a></li>";
			    })

			}

			$("#catedropdown").html(catelist);
		}, 'json');
	};

	 $(document).ready(function() {
		 getcatelist1();
