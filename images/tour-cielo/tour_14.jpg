<script type="text/javascript">
  function setDropDown(){
    $('.dropdown').hover(
	    function(){
	    	$('.dropdown-toggle', this).parent().addClass( "open" );
	      //$('.dropdown-toggle', this).trigger('click');
	    },
	    function(){
	    	$('.dropdown-toggle', this).parent().removeClass( "open" );
	    }
    );
  }
  $(document).ready(function(){
	  $(".open-sub-icon").click(function(){
		  if($(this).hasClass("open-sub-plus")){
			  $(this).parent().find(".dropdown-menu").first().addClass("click-plus");
			  $(this).parent().find(".dropdown-menu").find("a").css({"padding": "5px 15px 5px 25px"});
			  if($(this).parent().find(".dropdown").first().hasClass('sub')){
				  $(this).parent().find(".dropdown").first().removeClass('sub')
			  }

			  $(this).removeClass("fa-plus");
			  $(this).removeClass("open-sub-plus");
			  $(this).addClass("fa-minus");
		  }else{
			  $(this).parent().find(".dropdown-menu").first().removeClass("click-plus");
			  $(this).parent().find(".dropdown-menu").find("a").css({});
			  $(this).removeClass("fa-minus");
			  $(this).addClass("fa-plus");
			  $(this).addClass("open-sub-plus");
		  }
	  });
  });
</script>

<script>
	$(".carousel").swipe({

  swipe: function(event, direction, distance, duration, fingerCount, fingerData) {

    if (direction == 'left') $(this).carousel('next');
    if (direction == 'right') $(this).carousel('prev');

  },
  allowPageScroll:"vertical"

});
</script>
    
	
    <script id="empty-template" type="text/x-handlebars-template">
      <div class="EmptyMessage">No Tours found for your search.</div>
    </script>
    <script src="https://twitter.github.io/typeahead.js/js/handlebars.js"></script>
    <script type="text/javascript">

     jQuery(document).ready(function($) {
         oldPackageContent = "";
         setDropDown();
         (function (){
             var search = window.location.search;
             var index = search.indexOf("page=");
             var elems = $(".pagination > li");
             if(index==-1 && elems[0]){
                 elems[0].className="active";
                 return;
             }
             var currentPage = parseInt(search.substring(index+5,search.length));

             for(var i=0;i<elems.length;i++){
                    if(currentPage-1==i){
                        elems[i].className="active";
                        break;
                    }
             }
         })();

         var engine, remoteHost, template, empty;

         $.support.cors = true;

         empty = Handlebars.compile($("#empty-template").html());

         var engine = new Bloodhound({
             remote: {
                 url: 'https://thisiscozumel.com/tours/find?q=%QUERY%',
                 wildcard: '%QUERY%'
             },
             datumTokenizer: Bloodhound.tokenizers.whitespace('q'),
             queryTokenizer: Bloodhound.tokenizers.whitespace,
         });

         $('#search').typeahead({
                hint: $('.Typeahead-hint'),
                menu: $('.Typeahead-menu'),
                minLength: 3,
                classNames: {
                  open: 'is-open',
                  empty: 'is-empty',
                  cursor: 'is-active',
                  suggestion: 'Typeahead-suggestion',
                  selectable: 'Typeahead-selectable'
                }
              }, {
                source: engine.ttAdapter(),
                displayKey: 'screen_name',
                templates: {
                    empty: empty,
                    header: [
                        '<div class="list-group search-results-dropdown search-dropdown" style="width: 100%;">'
                    ],
                    suggestion: function (data) {
                        return '<a href="https://thisiscozumel.com/tours/packagedetails/' + data['slug'] + '" class="list-group-item search-item">' +  data['name'] + '</a>'
                    }
                },
                limit: 10,
         });

         $("#search").keyup(function(key){
             var code = key.which;
             if(code==13){
                 $(".tt-menu").hide();
                 searchCall(false);
             }
             if($("#search").val() == "" && isDisplayingSearchResult){
                $("#packageData").html(oldPackageContent);
                isDisplayingSearchResult = false;
             }
         });
     });

     function searchCall(sortflag){
         var query = $("#search").val();
         var sorting = $("#sorting").val();

         if(query != ""){
             if(!sortflag && oldPackageContent == ""){
                 oldPackageContent = $("#packageData").html();
             }
             $("#packageData").html('<div class="col-lg-8 col-md-8 col-sm-12 col-xs-12" style="text-align:center;"><img src="https://thisiscozumel.com/tours/img/loading.gif"></div>');
             if(sortflag){
                 var data = {query : query, sorting: sorting};
             }else{
                 var data = {query : query};
             }
             var url = "https://thisiscozumel.com/tours/package/search";
             $.get(url, data, function(res) {
                if(res) {
                    isDisplayingSearchResult = true;
                    $("#packageData").html(res);
                    $(".package-name").each(function () {
                        var regex = new RegExp( '(' + query + ')', 'gi' );
                        $(this).html($(this).html().replace(regex, '<font style="color:#fa8040;">'+query+'</font>'));
                    });
                }
             });
         }
     }

     function sortResult(){
         searchCall(true);
     }
    </script>
    <script src="https://www.jscache.com/wejs?wtype=selfserveprop&amp;uniq=883&amp;locationId=2471675&amp;lang=en_US&amp;rating=true&amp;nreviews=0&amp;writereviewlink=false&amp;popIdx=false&amp;iswide=false&amp;border=false&amp;display_version=2"></script>
      </body>
</html>
